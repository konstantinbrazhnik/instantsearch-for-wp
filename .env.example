# ============================================================
# InstantSearch for WP — Dev Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials.
# ============================================================

# ----- Algolia Credentials (required for Algolia provider) -----
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_SEARCH_ONLY_API_KEY=your_algolia_search_only_api_key
ALGOLIA_ADMIN_API_KEY=your_algolia_admin_api_key

# ----- Search Provider -----
# Options: algolia | typesense
SEARCH_PROVIDER=typesense

# ----- Typesense (used for local dev — runs in Docker) -----
TYPESENSE_API_KEY=dev-typesense-api-key
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# ----- WordPress Dev Site -----
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@instantsearch-dev.local
WP_SITE_TITLE=InstantSearch Dev
WP_SITE_URL=http://instantsearch-dev.local:8080

# ----- Database -----
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress

# ----- GitHub (preserved from existing .env) -----
# GITHUB_TOKEN=your_token_here
